{
	"name": "@joshuafolkken/game-kit",
	"version": "0.87.0",
	"keywords": [
		"svelte"
	],
	"files": [
		"dist",
		"templates",
		"!dist/**/*.test.*",
		"!templates/tsconfig.json"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"bin": {
		"jgame": "dist/scripts/jgame.js"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build && pnpm run prepack",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''; command -v lefthook >/dev/null 2>&1 && lefthook install; command -v tsx >/dev/null 2>&1 && tsx node_modules/@joshuafolkken/kit/scripts/fix-gh-packages.ts; true",
		"build:scripts": "pnpm exec esbuild scripts/jgame.ts --bundle --platform=node --packages=external --outdir=dist/scripts/ --format=esm --banner:js='#!/usr/bin/env node'",
		"prepack": "svelte-kit sync && svelte-package && pnpm run build:scripts && publint",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"gen": "pnpm gen:pre && wrangler types",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"josh": "josh",
		"size-limit": "size-limit"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/kit": "0.184.0",
		"@playwright/test": "1.60.0",
		"@size-limit/file": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.20.1",
		"@types/node": "^25.9.1",
		"@types/three": "^0.184.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.7",
		"cookie": "^1.1.1",
		"cspell": "^10.0.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"three": "^0.184.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1",
		"workbox-build": "^7.4.1",
		"workbox-window": "^7.4.1",
		"wrangler": "^4.94.0"
	},
	"peerDependencies": {
		"@threlte/core": ">=8.0.0",
		"@threlte/extras": ">=9.0.0",
		"svelte": "^5.0.0",
		"three": ">=0.180.0"
	},
	"packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0-0",
			"onFail": "error"
		}
	},
	"size-limit": [
		{
			"path": "./dist/index.js",
			"limit": "500 kB"
		}
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js"
}
