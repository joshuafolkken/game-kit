{
	"name": "@joshuafolkken/game-kit",
	"version": "0.12.0",
	"keywords": [
		"svelte"
	],
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build && pnpm run prepack",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"gen": "pnpm gen:pre && wrangler types",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"postinstall": "lefthook install && tsx node_modules/@joshuafolkken/kit/scripts/fix-gh-packages.ts",
		"josh": "josh",
		"size-limit": "size-limit"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/kit": "0.162.0",
		"@playwright/test": "1.59.1",
		"@size-limit/file": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@threlte/core": "^8.5.14",
		"@threlte/extras": "^9.16.0",
		"@types/node": "^25.6.2",
		"@types/three": "^0.184.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.5",
		"cookie": "^1.1.1",
		"cspell": "^10.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.20",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"three": "^0.184.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1",
		"workbox-build": "^7.4.1",
		"workbox-window": "^7.4.1",
		"wrangler": "^4.90.0"
	},
	"peerDependencies": {
		"@threlte/core": ">=8.0.0",
		"@threlte/extras": ">=9.0.0",
		"svelte": "^5.0.0",
		"three": ">=0.180.0"
	},
	"packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0-0",
			"onFail": "error"
		}
	},
	"size-limit": [
		{
			"path": "./dist/index.js",
			"limit": "500 kB"
		}
	],
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.0",
			"serialize-javascript": ">=7.0.5"
		},
		"onlyBuiltDependencies": [
			"@joshuafolkken/kit",
			"esbuild",
			"lefthook",
			"sharp",
			"unrs-resolver",
			"workerd"
		]
	},
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js"
}
