{
	"name": "@joshuafolkken/game-kit",
	"version": "0.173.0",
	"keywords": [
		"svelte"
	],
	"files": [
		"dist",
		"eslint",
		"templates",
		"cspell",
		"svelte.config.js",
		"src/app.d.ts",
		"!dist/**/*.test.*",
		"!templates/tsconfig.json"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./eslint/game": "./eslint/game.js",
		"./cspell/game": "./cspell/game.yaml"
	},
	"imports": {
		"#scripts/*": "./scripts/*"
	},
	"bin": {
		"jgame": "dist/scripts/jgame.js"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build && pnpm run prepack",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm prepare:gen && pnpm prepare:sync && pnpm prepare:lefthook && pnpm prepare:gh-packages",
		"prepare:gen": "[ ! -f wrangler.jsonc ] || pnpm gen",
		"prepare:sync": "svelte-kit sync || echo ''",
		"prepare:lefthook": "[ -n \"$CI\" ] || ! command -v lefthook >/dev/null 2>&1 || lefthook install",
		"prepare:gh-packages": "[ -n \"$CI\" ] || ! command -v tsx >/dev/null 2>&1 || tsx node_modules/@joshuafolkken/kit/scripts/fix-gh-packages.ts",
		"build:scripts": "pnpm exec esbuild scripts/jgame.ts --bundle --platform=node --packages=external --outdir=dist/scripts/ --format=esm --banner:js='#!/usr/bin/env node'",
		"reconcile-templates": "tsx scripts/templates/reconcile-templates.ts",
		"prepack": "svelte-kit sync && svelte-package && pnpm run build:scripts && publint",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"gen": "pnpm gen:pre && wrangler types",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"josh": "josh",
		"size-limit": "size-limit"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/app-kit": "^0.25.0",
		"@joshuafolkken/kit": "0.283.0",
		"@playwright/test": "1.61.1",
		"@size-limit/file": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"@types/node": "^26.0.1",
		"@types/three": "^0.185.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.9",
		"cspell": "^10.0.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"lefthook": "^2.1.9",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"three": "^0.185.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.0",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.0",
		"workbox-build": "^7.4.1",
		"workbox-window": "^7.4.1",
		"wrangler": "^4.105.0"
	},
	"peerDependencies": {
		"@joshuafolkken/app-kit": ">=0.20.0",
		"@threlte/core": ">=8.0.0",
		"@threlte/extras": ">=9.0.0",
		"svelte": "^5.0.0",
		"three": ">=0.180.0"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.9.0",
			"onFail": "error"
		}
	},
	"size-limit": [
		{
			"path": "./dist/index.js",
			"limit": "500 kB"
		}
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js"
}
